# Copy to .env.prod (gitignored) on the NAS and fill in real values.
# Lock down: chmod 600 .env.prod

# --- Host paths ---
# Dedicated ZFS dataset for this app's persistent state.
# Subdirs created automatically by deploy.sh: postgres/, uploads/, share/
DATA_DIR=/mnt/tank/apps/eventPhotos/data

# Host port nginx publishes on. Nginx Proxy Manager proxies to <nas-lan-ip>:<port>.
HOST_HTTP_PORT=8081

# --- Symfony ---
APP_ENV=prod
APP_DEBUG=0
# Generate with: openssl rand -hex 32
APP_SECRET=__REPLACE_ME__
# Public URL the app is reached at (used in emails, CLI URL generation).
DEFAULT_URI=https://photos.example.com
APP_SHARE_DIR=var/share
# Trust X-Forwarded-* headers from Nginx Proxy Manager so URL generation,
# secure cookies, and request scheme detection work behind the proxy.
TRUSTED_PROXIES=REMOTE_ADDR

# --- Database (Postgres container) ---
POSTGRES_DB=eventPhotos
POSTGRES_USER=eventPhotos
POSTGRES_PASSWORD=__REPLACE_ME__
DATABASE_URL=postgresql://eventPhotos:__REPLACE_ME__@database:5432/eventPhotos?serverVersion=16&charset=utf8

# --- Mailer ---
# Real SMTP DSN. Examples:
#   smtp://user:pass@smtp.example.com:587
#   sendgrid+smtp://KEY:@default
MAILER_DSN=smtp://localhost:1025

# --- Messenger ---
MESSENGER_TRANSPORT_DSN=doctrine://default?queue_name=async

# --- Google SSO (optional) ---
# Leave empty to disable Google sign-in entirely (buttons hidden, /oauth/google/* returns 404).
# To enable: create a Web-application OAuth client in Google Cloud Console with redirect URI
# https://<your-domain>/oauth/google/callback — see docs/setup/google-sso-prod.md.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
