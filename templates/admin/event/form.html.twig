{% extends 'admin/_base.html.twig' %}

{% block title %}Admin — {{ mode == 'new' ? 'New event' : 'Edit ' ~ event.name }}{% endblock %}

{% block admin_breadcrumb %}
    <div class="breadcrumbs text-sm">
        <ul>
            <li>Admin</li>
            <li><a href="{{ path('admin_event_index') }}" class="link link-hover">Events</a></li>
            <li>{{ mode == 'new' ? 'New' : 'Edit' }}</li>
        </ul>
    </div>
{% endblock %}

{% block admin_main %}
    <header class="mb-6">
        <h1 class="text-2xl font-semibold">
            {{ mode == 'new' ? 'New event' : 'Edit ' ~ event.name }}
        </h1>
    </header>

    {{ form_start(form, {attr: {id: 'event-form', class: 'card bg-base-100 shadow-sm'}}) }}
        {% if event.logoFilename ?? false %}
            <div class="px-6 pt-6 flex items-center gap-3">
                <span class="text-sm font-medium">Current logo:</span>
                <img src="{{ path('admin_event_logo', {id: event.id}) }}"
                     alt="Event logo"
                     class="h-16 w-16 object-contain border rounded bg-base-200" />
            </div>
        {% endif %}
        <div class="card-body grid gap-4 lg:grid-cols-2">
            {{ form_widget(form) }}
        </div>
    {{ form_end(form, {render_rest: false}) }}

    {% if mode == 'edit' %}
        <section class="card bg-base-100 shadow-sm mt-6">
            <div class="card-body gap-4">
                <h2 class="card-title text-lg">Visitor notifications</h2>

                {% if not mailActive %}
                    <p class="text-sm text-base-content/70">
                        Configure and verify a
                        <a href="{{ path('admin_account_mail_edit') }}" class="link">custom mail transport</a>
                        before enabling visitor "photos are live" notifications.
                    </p>
                {% else %}
                    <p class="text-sm text-base-content/70">
                        Sign-ups are currently
                        <strong>{{ event.areNotificationsEnabled ? 'open' : 'closed' }}</strong> —
                        control this with the “Allow participants to request email updates” checkbox above.
                    </p>

                    <p class="text-sm text-base-content/70">{{ subscriberCount }} subscriber(s) so far.</p>

                    {% if event.isPublished %}
                        <p class="text-sm">Published {{ event.publishedAt|date('Y-m-d H:i') }} — notifications sent.</p>
                    {% else %}
                        <form method="post" action="{{ path('admin_event_publish', {id: event.id}) }}" class="flex flex-col gap-2">
                            <input type="hidden" name="_token" value="{{ csrf_token('publish' ~ event.id) }}">
                            <span class="text-sm">
                                Publishing notifies confirmed subscribers — sends complete in ~{{ projectedMinutes }} minute(s).
                            </span>
                            <button
                                type="submit"
                                class="btn btn-primary btn-sm w-fit"
                                {{ readyPhotoCount < 1 ? 'disabled' }}
                            >
                                Publish & notify
                            </button>
                            {% if readyPhotoCount < 1 %}
                                <span class="text-xs text-base-content/60">Add at least one ready photo before publishing.</span>
                            {% endif %}
                        </form>
                    {% endif %}
                {% endif %}
            </div>
        </section>
    {% endif %}
{% endblock %}

{% block admin_actions %}
    <a href="{{ path('admin_event_index') }}" class="btn btn-ghost">Cancel</a>
    <button type="submit" form="event-form" class="btn btn-primary">
        {{ mode == 'new' ? 'Create' : 'Save' }}
    </button>
{% endblock %}
