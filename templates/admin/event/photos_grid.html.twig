<turbo-frame id="photos-grid">
    {% if hasStalePending %}
        <div class="alert alert-warning my-4">
            Some photos look stuck. Is the worker running?
            <code>bin/console messenger:consume async failed -vv</code>
        </div>
    {% endif %}

    {% if total == 0 %}
        <p class="text-base-content/70">No photos yet. Drop some files above.</p>
    {% elseif photos|length == 0 %}
        <p class="text-base-content/70">No photos on this page.</p>
    {% else %}
        <div class="overflow-x-auto rounded-box border border-base-300 bg-base-100">
            <table class="table table-zebra">
                <thead>
                    <tr>
                        <th>Thumb</th>
                        <th>Filename</th>
                        <th>Taken at</th>
                        <th>Uploaded at</th>
                        <th>Dimensions</th>
                        <th>Size</th>
                        <th>Status</th>
                        <th class="text-right">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% for photo in photos %}
                        {{ include('admin/event/_photo_row.html.twig', {event: event, photo: photo, page: page}) }}
                    {% endfor %}
                </tbody>
            </table>
        </div>
    {% endif %}

    {% set lastPage = (total > 0) ? ((total - 1) // perPage) + 1 : 1 %}
    {% if lastPage > 1 %}
        <nav class="mt-4 flex items-center justify-between text-sm">
            <div class="text-base-content/70">
                {% set from = (page - 1) * perPage + 1 %}
                {% set to   = min(page * perPage, total) %}
                Showing {{ from }}–{{ to }} of {{ total }}
            </div>
            <div class="inline-flex items-center gap-2">
                {% if page > 1 %}
                    <a href="{{ path('admin_photo_grid', {id: event.id, page: page - 1}) }}"
                       class="btn btn-ghost btn-sm">‹ Prev</a>
                {% endif %}
                <span class="px-2">Page {{ page }} of {{ lastPage }}</span>
                {% if page < lastPage %}
                    <a href="{{ path('admin_photo_grid', {id: event.id, page: page + 1}) }}"
                       class="btn btn-ghost btn-sm">Next ›</a>
                {% endif %}
            </div>
        </nav>
    {% endif %}

    {% if event.bibIndexingEnabled %}
        <form method="post"
              action="{{ path('admin_bib_suppress', {id: event.id}) }}"
              class="mt-6 flex items-end gap-2">
            <label class="form-control">
                <span class="label-text">De-index a bib number</span>
                <input type="text" name="bibNumber" class="input input-bordered input-sm" maxlength="64" required>
            </label>
            <input type="hidden" name="_token"
                   value="{{ csrf_token('suppress_bib_' ~ event.id) }}">
            <button type="submit" class="btn btn-sm">Suppress</button>
        </form>
    {% endif %}

    {% if total > 0 %}
        <div class="mt-6 flex items-center justify-end gap-2 border-t border-base-300 pt-4">
            {% if event.retainOriginals and failedCount > 0 %}
                <form method="post"
                      action="{{ path('admin_photo_retry_all', {id: event.id}) }}"
                      onsubmit="return confirm('Retry all {{ failedCount }} failed photo{{ failedCount != 1 ? 's' : '' }}? Each is re-ingested from its original and the ingest window guard re-applies.');"
                      class="inline">
                    <input type="hidden" name="_token" value="{{ csrf_token('retry_all_photos_' ~ event.id) }}">
                    <button type="submit" class="btn btn-outline btn-warning btn-sm">
                        Retry all failed ({{ failedCount }})
                    </button>
                </form>
            {% endif %}
            {% if event.retainOriginals %}
                <form method="post"
                      action="{{ path('admin_photo_reingest_all', {id: event.id}) }}"
                      onsubmit="return confirm('Re-ingest all {{ total }} photo{{ total != 1 ? 's' : '' }}? Every thumbnail and preview will be regenerated from the originals using the current display settings.');"
                      class="inline">
                    <input type="hidden" name="_token" value="{{ csrf_token('reingest_all_photos_' ~ event.id) }}">
                    <button type="submit" class="btn btn-outline btn-sm">Re-ingest all photos</button>
                </form>
            {% endif %}
            <div data-controller="delete-all-photos"
                 data-delete-all-photos-expected-value="{{ event.name }}"
                 class="inline">
                <button type="button"
                        class="btn btn-error btn-sm"
                        data-action="click->delete-all-photos#open">
                    Delete all photos
                </button>
                <dialog class="modal" data-delete-all-photos-target="dialog">
                    <div class="modal-box">
                        <h3 class="text-lg font-bold">Delete all photos for "{{ event.name }}"?</h3>
                        <p class="py-2">
                            This will permanently delete {{ total }} photo{% if total != 1 %}s{% endif %}
                            and their files. This action cannot be undone.
                        </p>
                        <p class="text-sm">To confirm, type the event name <strong>{{ event.name }}</strong> below:</p>
                        <input type="text"
                               class="input input-bordered w-full mt-2"
                               autocomplete="off"
                               data-delete-all-photos-target="input"
                               data-action="input->delete-all-photos#check">
                        <div class="modal-action">
                            <form method="dialog"><button class="btn">Cancel</button></form>
                            <form method="post"
                                  action="{{ path('admin_photo_delete_all', {id: event.id}) }}">
                                <input type="hidden" name="_token"
                                       value="{{ csrf_token('delete_all_photos_' ~ event.id) }}">
                                <button type="submit"
                                        class="btn btn-error"
                                        data-delete-all-photos-target="submit"
                                        disabled>
                                    Delete all
                                </button>
                            </form>
                        </div>
                    </div>
                    <form method="dialog" class="modal-backdrop"><button>close</button></form>
                </dialog>
            </div>
        </div>
    {% endif %}
</turbo-frame>
