{% extends 'admin/_base.html.twig' %}

{% block title %}Admin — Import event{% endblock %}

{% block admin_breadcrumb %}
    <div class="breadcrumbs text-sm">
        <ul>
            <li>Admin</li>
            <li><a href="{{ path('admin_event_index') }}" class="link link-hover">Events</a></li>
            <li>Import</li>
        </ul>
    </div>
{% endblock %}

{% block admin_main %}
    <header class="mb-6">
        <h1 class="text-2xl font-semibold">Import event</h1>
    </header>

    {{ form_start(form, {attr: {class: 'card bg-base-100 shadow-sm'}}) }}
        <div class="card-body space-y-4">
            {{ form_row(form.archive) }}
            {% if form.owner is defined %}
                {{ form_row(form.owner) }}
            {% endif %}
            <div>
                <button type="submit" class="btn btn-primary">Import</button>
            </div>
        </div>
    {{ form_end(form) }}
{% endblock %}
