{% extends 'admin/_base.html.twig' %}

{% block title %}Sessions — {{ target.email }}{% endblock %}

{% block admin_breadcrumb %}
    <div class="breadcrumbs text-sm">
        <ul>
            <li>Admin</li>
            <li><a href="{{ path('admin_user_index') }}">Users</a></li>
            <li><a href="{{ path('admin_user_edit', {id: target.id}) }}">{{ target.email }}</a></li>
            <li>Sessions</li>
        </ul>
    </div>
{% endblock %}

{% block admin_main %}
<div class="mx-auto max-w-4xl space-y-6">
    <div class="flex items-center justify-between">
        <div>
            <h1 class="text-2xl font-semibold">Sessions</h1>
            <p class="text-sm text-base-content/60 mt-1">Viewing active sessions for {{ target.email }}.</p>
        </div>
        <a href="{{ path('admin_user_edit', {id: target.id}) }}" class="btn btn-sm btn-ghost">← Back to user</a>
    </div>

    <div class="overflow-x-auto border border-base-300 rounded-box">
        <table class="table table-sm">
            <thead>
            <tr>
                <th>Device</th>
                <th>IP / Country</th>
                <th>Last active</th>
                <th>Label</th>
                <th></th>
            </tr>
            </thead>
            <tbody>
            {% for s in sessions %}
                <tr class="border-t">
                    <td class="align-top" title="{{ s.userAgent }}">
                        {{ s.userAgentDisplay ?? s.userAgent|slice(0, 60) }}
                    </td>
                    <td class="align-top">
                        {{ s.ip }}{% if s.countryCode %} · {{ s.countryCode }}{% endif %}
                    </td>
                    <td class="align-top" title="{{ s.lastSeenAt|date('Y-m-d H:i:s') }}">
                        {{ s.lastSeenAt|date('Y-m-d H:i') }}
                    </td>
                    <td class="align-top text-base-content/60">{{ s.label ?? '—' }}</td>
                    <td class="align-top">
                        <form method="post" action="{{ path('admin_user_sessions_revoke', {id: target.id, sessId: s.sessId}) }}">
                            <input type="hidden" name="_token" value="{{ csrf_token('user_session_revoke') }}">
                            <button type="submit"
                                    class="btn btn-xs btn-error btn-outline"
                                    onclick="return confirm('Revoke this session?')">
                                Revoke
                            </button>
                        </form>
                    </td>
                </tr>
            {% else %}
                <tr><td colspan="5" class="py-6 text-center text-base-content/50">No active sessions.</td></tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}
