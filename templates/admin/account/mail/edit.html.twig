{% extends 'admin/_base.html.twig' %}

{% block title %}Mail configuration{% endblock %}

{% block admin_breadcrumb %}
    <div class="breadcrumbs text-sm">
        <ul>
            <li>Admin</li>
            <li><a href="{{ path('account_show') }}">My account</a></li>
            <li>Mail configuration</li>
        </ul>
    </div>
{% endblock %}

{% block admin_main %}
<div class="mx-auto max-w-2xl space-y-6">
    <div>
        <h1 class="text-2xl font-semibold">Mail configuration</h1>
        <p class="mt-1 text-sm text-base-content/60">
            Configure an SMTP transport so event emails are sent from your own domain.
            Without a verified configuration, event mail goes out from the platform default.
        </p>
    </div>

    <div>
        {% if config is null %}
            <span class="badge badge-ghost">Not configured</span>
        {% elseif config.verified %}
            <span class="badge badge-success">Verified</span>
            <span class="ml-2 text-xs text-base-content/60">
                since {{ config.verifiedAt|date('Y-m-d H:i') }}
            </span>
        {% else %}
            <span class="badge badge-warning">Pending verification</span>
            <span class="ml-2 text-xs text-base-content/60">
                sent {{ config.verificationSentAt|date('Y-m-d H:i') }}
            </span>
        {% endif %}
    </div>

    {{ form_start(form, {attr: {class: 'space-y-4'}}) }}
        {{ form_row(form.dsn) }}
        {{ form_row(form.fromAddr) }}
        {{ form_row(form.fromName) }}
        <button type="submit" class="btn btn-primary">Save and send verification</button>
    {{ form_end(form) }}

    {% if config is not null %}
        <div class="flex gap-3">
            <form method="post" action="{{ path('admin_account_mail_resend') }}">
                <input type="hidden" name="_token" value="{{ csrf_token('mail_config_resend') }}">
                <button type="submit" class="btn btn-sm btn-ghost">Resend verification</button>
            </form>
            <form method="post" action="{{ path('admin_account_mail_clear') }}"
                  data-turbo-confirm="Clear mail configuration? Event mail will fall back to the platform default.">
                <input type="hidden" name="_token" value="{{ csrf_token('mail_config_clear') }}">
                <button type="submit" class="btn btn-sm btn-ghost text-error">Clear configuration</button>
            </form>
        </div>
    {% endif %}
</div>
{% endblock %}
