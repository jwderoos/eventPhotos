{% extends 'public/_base.html.twig' %}

{% block title %}{{ event.name }} — Photos{% endblock %}

{% block public_main %}
    <style>
        .lightbox-track { transform: translate3d(0, 0, 0); }
        .lightbox-track.is-animating { transition: transform 250ms cubic-bezier(0.22, 0.61, 0.36, 1); }
    </style>
    <section class="space-y-6">
        <header class="space-y-4">
            <h1 class="text-2xl font-semibold">{{ event.name }}</h1>

            <form method="get"
                  action="{{ path('public_event_photos', {slug: event.slug}) }}"
                  data-testid="attribute-filter"
                  class="flex flex-wrap items-end gap-4 text-sm">
                <fieldset class="flex flex-wrap gap-2">
                    <legend class="w-full text-xs uppercase text-base-content/60">Colour</legend>
                    {% for colour in allowedColours %}
                        <label class="flex items-center gap-1">
                            <input type="checkbox" name="colour[]" value="{{ colour }}"
                                   {{ colour in filter.colours ? 'checked' }}
                                   class="checkbox checkbox-xs">
                            <span>{{ colour }}</span>
                        </label>
                    {% endfor %}
                </fieldset>
                <fieldset class="flex flex-wrap gap-2">
                    <legend class="w-full text-xs uppercase text-base-content/60">Garment</legend>
                    {% for garment in allowedGarments %}
                        <label class="flex items-center gap-1">
                            <input type="checkbox" name="garment[]" value="{{ garment }}"
                                   {{ garment in filter.garments ? 'checked' }}
                                   class="checkbox checkbox-xs">
                            <span>{{ garment|replace({'-': ' '}) }}</span>
                        </label>
                    {% endfor %}
                </fieldset>
                {% if bibSearchEnabled %}
                    <label class="flex flex-col gap-1">
                        <span class="text-xs uppercase text-base-content/60">Bib number</span>
                        <input type="text" name="bib" inputmode="numeric"
                               data-testid="bib-filter"
                               value="{{ filter.bib }}"
                               class="input input-sm input-bordered w-28">
                    </label>
                {% endif %}
                <button type="submit" class="btn btn-sm btn-primary">Search</button>
                {% if searchMode %}
                    <a href="{{ path('public_event_photos', {slug: event.slug}) }}" class="btn btn-sm btn-ghost">Clear</a>
                {% endif %}
            </form>

            {% if not searchMode %}
                <form method="get"
                      action="{{ path('public_event_photos', {slug: event.slug}) }}"
                      data-testid="time-filter"
                      class="flex flex-wrap items-center gap-2 text-sm">
                    <label for="photos-time" class="sr-only">Time</label>
                    <input type="time"
                           id="photos-time"
                           name="t"
                           value="{{ timestamp|date('H:i', event.timezone) }}"
                           class="input input-sm input-bordered w-28">
                    <button type="submit" class="btn btn-sm">Update</button>
                </form>

                {% set nav_targets = {
                    'first': firstAt,
                    'prev':  prevAt,
                    'next':  nextAt,
                    'last':  lastAt,
                } %}
                {% set nav_labels = {
                    'first': '« First',
                    'prev':  '‹ Previous',
                    'next':  'Next ›',
                    'last':  'Last »',
                } %}

                <nav data-testid="cross-window-nav"
                     aria-label="Photo timeline navigation"
                     class="flex flex-wrap items-center gap-1 text-sm">
                    {% for key, target in nav_targets %}
                        {% if target is null %}
                            <span data-testid="nav-{{ key }}"
                                  aria-disabled="true"
                                  class="btn btn-sm btn-disabled pointer-events-none opacity-50">
                                {{ nav_labels[key] }}
                            </span>
                        {% else %}
                            <span data-testid="nav-{{ key }}">
                                <a href="{{ path('public_event_photos', {
                                        slug: event.slug,
                                        t:    target|date('H:i', event.timezone),
                                   }) }}"
                                   class="btn btn-sm">
                                    {{ nav_labels[key] }}
                                </a>
                            </span>
                        {% endif %}
                    {% endfor %}
                </nav>

                <p class="text-sm text-base-content/70">
                    Showing
                    <time data-testid="timestamp" datetime="{{ timestamp|date('c') }}">{{ timestamp|date('H:i', event.timezone) }}</time>
                    · Window: <span data-testid="window">−{{ windowBefore }} / +{{ windowAfter }}</span> min
                    · <span data-testid="photo-count">{{ photos|length }} of {{ totalReady }}</span> photo{{ totalReady == 1 ? '' : 's' }}
                </p>
            {% else %}
                <p class="text-sm text-base-content/70">
                    <span data-testid="photo-count">{{ photos|length }}</span> matching photo{{ photos|length == 1 ? '' : 's' }}
                </p>
            {% endif %}
        </header>

        {% include 'public/event/_photo_grid.html.twig' %}

        <p>
            <a href="{{ path('public_event_landing', {slug: event.slug}) }}" class="btn btn-ghost btn-sm">
                ← Back to event
            </a>
        </p>
    </section>
{% endblock %}
