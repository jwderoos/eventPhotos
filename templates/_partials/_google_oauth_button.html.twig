{# Compliant Google sign-in button per Google Identity branding guidelines.
   Required params: href. Optional: testid, variant ('light' | 'dark', default 'light').
   Label is fixed to "Continue with Google" — applies to sign-in, sign-up, and account linking. #}
{% set variant = variant|default('light') %}
{% set classes = variant == 'dark'
    ? 'border-[#8E918F] bg-[#131314] text-[#E3E3E3] hover:bg-[#1F1F20]'
    : 'border-[#747775] bg-white text-[#1F1F1F] hover:bg-[#F8F9FA]' %}
<a href="{{ href }}"
   {% if testid is defined %}data-testid="{{ testid }}"{% endif %}
   class="inline-flex h-10 w-full items-center justify-center gap-3 rounded-md border px-4 text-sm font-medium tracking-[0.01em] transition-colors {{ classes }}">
    {% include '_partials/_provider_logo.html.twig' with {provider: 'google', class: 'h-5 w-5'} only %}
    <span>Continue with Google</span>
</a>
