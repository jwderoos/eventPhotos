{% extends 'admin/_base.html.twig' %}

{% block title %}Reset password{% endblock %}

{% block admin_shell %}
    <div class="flex min-h-screen items-center justify-center bg-base-200 px-4">
        <div class="card w-full max-w-sm bg-base-100 shadow-md">
            <div class="card-body gap-4">
                <h1 class="card-title justify-center text-xl">Reset your password</h1>

                {% for flash in app.flashes('reset_password_error') %}
                    <div data-testid="reset-error" class="alert alert-error" role="alert">
                        <span>{{ flash }}</span>
                    </div>
                {% endfor %}

                <p class="text-sm text-base-content/70">
                    Enter the email associated with your account. If it matches an account, we'll send a reset link.
                </p>

                {{ form_start(requestForm, {attr: {class: 'space-y-3'}}) }}
                    {{ form_row(requestForm.email, {
                        label: 'Email',
                        label_attr: {class: 'label-text'},
                        row_attr: {class: 'form-control w-full'},
                        attr: {class: 'input input-bordered w-full'},
                    }) }}
                    <button type="submit" class="btn btn-primary w-full">Send reset link</button>
                {{ form_end(requestForm) }}

                <p class="text-sm text-center">
                    <a href="{{ path('app_login') }}" class="link">Back to sign in</a>
                </p>
            </div>
        </div>
    </div>
{% endblock %}
