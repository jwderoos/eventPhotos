{
    "name": "jwderoos/event-photos",
    "description": "Time aware photo event manager",
    "license": "proprietary",
    "type": "project",
    "autoload": {
        "psr-4": {
            "Jwderoos\\EventPhotos\\": "src/"
        }
    },
    "require": {
        "php": "^8.5"
    },
    "require-dev": {
        "phpunit/phpunit": "^13.2",
        "phpstan/phpstan": "^2.2",
        "rector/rector": "^2.4",
        "phpro/grumphp": "^2.21",
        "sbrindle/phpcpd": "^7.0",
        "roave/security-advisories": "dev-latest",
        "phpstan/phpstan-beberlei-assert": "^2.0",
        "phpstan/phpstan-phpunit": "^2.0",
        "phpstan/extension-installer": "^1.4",
        "phpmd/phpmd": "^2.5",
        "squizlabs/php_codesniffer": "^4.0",
        "povils/phpmnd": "^3.6"
    },
    "config": {
        "allow-plugins": {
            "phpro/grumphp": true,
            "phpstan/extension-installer": true
        }
    }
}
