{
    "name": "jwderoos/event-photos",
    "description": "Time aware photo event manager",
    "license": "proprietary",
    "type": "project",
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "require": {
        "php": "^8.5",
        "ext-ctype": "*",
        "ext-dom": "*",
        "ext-exif": "*",
        "ext-fileinfo": "*",
        "ext-gd": "*",
        "ext-iconv": "*",
        "ext-intl": "*",
        "ext-mbstring": "*",
        "ext-pdo": "*",
        "ext-pdo_pgsql": "*",
        "ext-simplexml": "*",
        "ext-tokenizer": "*",
        "symfony/framework-bundle": "^8.0",
        "symfony/runtime": "^8.1",
        "symfony/dotenv": "^8.1",
        "symfony/yaml": "^8.1",
        "symfony/console": "^8.0",
        "symfony/twig-bundle": "^8.1",
        "symfony/asset-mapper": "^8.1",
        "symfony/asset": "^8.1",
        "symfony/stimulus-bundle": "^3.1",
        "symfony/ux-turbo": "^3.1",
        "symfony/form": "^8.1",
        "symfony/validator": "^8.1",
        "symfony/security-bundle": "^8.0",
        "symfony/translation": "^8.1",
        "symfony/mailer": "^8.1",
        "doctrine/doctrine-bundle": "^3.2",
        "doctrine/doctrine-migrations-bundle": "^4.0",
        "symfony/flex": "^2.11",
        "doctrine/orm": "^3",
        "doctrine/dbal": "^4",
        "symfony/monolog-bundle": "^4.0",
        "symfonycasts/tailwind-bundle": "^0.13.0",
        "endroid/qr-code": "^6",
        "vich/uploader-bundle": "^2.9",
        "league/flysystem-bundle": "^3.7",
        "symfony/messenger": "^8.1",
        "symfony/doctrine-messenger": "^8.1",
        "symfonycasts/reset-password-bundle": "^1.25"
    },
    "require-dev": {
        "phpunit/phpunit": "^13.2",
        "phpstan/phpstan": "^2.2",
        "rector/rector": "^2.4",
        "phpro/grumphp": "^2.21",
        "sbrindle/phpcpd": "^7.0",
        "roave/security-advisories": "dev-latest",
        "phpstan/phpstan-beberlei-assert": "^2.0",
        "phpstan/phpstan-phpunit": "^2.0",
        "phpstan/extension-installer": "^1.4",
        "phpmd/phpmd": "^2.5",
        "squizlabs/php_codesniffer": "^4.0",
        "povils/phpmnd": "^3.6",
        "symfony/maker-bundle": "^1.67",
        "symfony/web-profiler-bundle": "^8.1",
        "symfony/debug-bundle": "^8.1",
        "symfony/browser-kit": "^8.1",
        "symfony/css-selector": "^8.1",
        "phpstan/phpstan-symfony": "^2",
        "phpstan/phpstan-doctrine": "^2",
        "dama/doctrine-test-bundle": "^8.6",
        "league/flysystem-memory": "^3.31"
    },
    "config": {
        "allow-plugins": {
            "phpro/grumphp": true,
            "phpstan/extension-installer": true,
            "symfony/runtime": true,
            "symfony/flex": true
        }
    },
    "scripts": {
        "auto-scripts": {
            "cache:clear": "symfony-cmd",
            "assets:install %PUBLIC_DIR%": "symfony-cmd",
            "importmap:install": "symfony-cmd"
        }
    }
}
